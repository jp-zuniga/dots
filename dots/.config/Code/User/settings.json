{
    "better-comments.tags": [
        {
            "tag": "*",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#98C379",
            "italic": true,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "!",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#FF2D00",
            "italic": false,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "?",
            "backgroundColor": "transparent",
            "bold": false,
            "color": "#3498DB",
            "italic": true,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "todo",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#FF8C00",
            "italic": false,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "//",
            "backgroundColor": "transparent",
            "bold": false,
            "color": "#474747",
            "italic": false,
            "strikethrough": true,
            "underline": false,
        },
    ],
    "chat.agent.enabled": false,
    "clangd.inactiveRegions.opacity": 0.6,
    "codesnap.containerPadding": "0",
    "codesnap.realLineNumbers": true,
    "codesnap.roundedCorners": false,
    "codesnap.showWindowControls": false,
    "codesnap.target": "window",
    "codesnap.transparentBackground": true,
    "editor.accessibilitySupport": "off",
    "editor.fontFamily": "MesloLGM Nerd Font, monospace",
    "editor.minimap.renderCharacters": false,
    "editor.minimap.size": "fit",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.exclude": {
        "**/.git": false,
    },
    "files.readonlyInclude": {
        "**/.cargo/registry/src/**/*.rs": true,
        "**/.cargo/git/checkouts/**/*.rs": true,
        "**/lib/rustlib/src/rust/library/**/*.rs": true,
    },
    "files.trimTrailingWhitespace": true,
    "git.enableSmartCommit": true,
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "ruff.nativeServer": "on",
    "rust-analyzer.showDependenciesExplorer": false,
    "rust-analyzer.diagnostics.enable": false,
    "rust-analyzer.restartServerOnConfigChange": true,
    "rust-analyzer.inlayHints.chainingHints.enable": false,
    "rust-analyzer.inlayHints.typeHints.enable": false,
    "rust-analyzer.inlayHints.renderColons": false,
    "rust-analyzer.inlayHints.typeHints.hideClosureInitialization": true,
    "rust-analyzer.inlayHints.typeHints.hideClosureParameter": true,
    "rust-analyzer.inlayHints.typeHints.hideNamedConstructor": true,
    "rust-analyzer.lens.enable": false,
    "security.workspace.trust.untrustedFiles": "newWindow",
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.linux": "Nushell",
    "terminal.integrated.fontFamily": "MesloLGM Nerd Font",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.profiles.linux": {
        "bash": null,
        "JavaScript Debug Terminal": null,
    },
    "terminal.integrated.profiles.windows": {
        "JavaScript Debug Terminal": null,
    },
    "update.showReleaseNotes": false,
    "window.commandCenter": false,
    "workbench.activityBar.location": "top",
    "workbench.cloudChanges.autoResume": "off",
    "workbench.cloudChanges.continueOn": "off",
    "workbench.enableExperiments": false,
    "workbench.layoutControl.enabled": false,
    "workbench.navigationControl.enabled": false,
    "workbench.preferredDarkColorTheme": "Rosé Pine Moon",
    "workbench.preferredLightColorTheme": "Rosé Pine Dawn",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "workbench.colorTheme": "Rosé Pine Moon",
    "workbench.productIconTheme": "material-product-icons",
    "python.createEnvironment.trigger": "off",
    "python.defaultInterpreterPath": "/bin/python3",
    "python.experiments.enabled": false,
    "python.languageServer": "Pylance",
    "python.pipenvPath": "",
    "python.pixiToolPath": "",
    "python.poetryPath": "",
    "python.REPL.enableREPLSmartSend": false,
    "python.REPL.provideVariables": false,
    "python.terminal.activateEnvironment": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": false,
    "python.testing.promptToConfigure": false,
    "python.testing.pytestPath": "",
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.enablePytestSupport": false,
    "python.analysis.generateWithTypeAnnotation": true,
    "python.analysis.languageServerMode": "full",
    "python.analysis.logLevel": "Error",
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.typeEvaluation.deprecateTypingAliases": true,
    "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
    "python.analysis.typeEvaluation.strictDictionaryInference": true,
    "python.analysis.typeEvaluation.strictListInference": true,
    "python.analysis.typeEvaluation.strictSetInference": true,
    "ruff.codeAction.disableRuleComment": {
        "enable": false
    },
    "evenBetterToml.formatter.allowedBlankLines": 1,
    "evenBetterToml.formatter.alignEntries": true,
    "evenBetterToml.formatter.alignComments": true,
    "evenBetterToml.formatter.arrayAutoCollapse": false,
    "evenBetterToml.formatter.arrayTrailingComma": true,
    "evenBetterToml.formatter.columnWidth": 80,
    "evenBetterToml.formatter.indentTables": true,
    "evenBetterToml.formatter.indentEntries": true,
    "evenBetterToml.formatter.inlineTableExpand": true,
    "evenBetterToml.formatter.reorderArrays": true,
    "evenBetterToml.formatter.reorderInlineTables": true,
    "evenBetterToml.formatter.reorderKeys": true,
    "evenBetterToml.formatter.trailingNewline": true,
    "evenBetterToml.schema.links": true,
    "evenBetterToml.semanticTokens": true,
    "editor.mouseWheelZoom": true,
    "editor.minimap.maxColumn": 90,
    "workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.showTabs": "none",
    "window.enableMenuBarMnemonics": false,
    "window.title": " ",
    "accessibility.hideAccessibleView": true,
    "accessibility.underlineLinks": true,
    "explorer.autoReveal": "focusNoScroll",
    "chat.commandCenter.enabled": false,
    "chat.detectParticipant.enabled": false,
    "chat.agent.maxRequests": 0,
    "chat.useFileStorage": false,
    "window.menuBarVisibility": "compact",
    "workbench.editor.editorActionsLocation": "hidden",
    "git.autofetch": true,
    "git.confirmSync": false,
    "workbench.iconTheme": "material-icon-theme",
    "git.openRepositoryInParentFolders": "never",
    "window.customTitleBarVisibility": "windowed",
    "window.titleBarStyle": "custom",
    "window.newWindowDimensions": "maximized",
    "window.restoreFullscreen": true,
    "evenBetterToml.completion.maxKeys": 3,
    "betterAlign.operatorPadding": "left",
    "betterAlign.indentBase": "dontchange",
    "betterAlign.surroundSpace": {
        "colon": [
            -1,
            1
        ],
        "assignment": [
            1,
            1
        ],
        "arrow": [
            1,
            1
        ],
        "comment": 2
    },
}