{
    "better-comments.tags": [
        {
            "tag": "*",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#98C379",
            "italic": true,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "!",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#FF2D00",
            "italic": false,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "?",
            "backgroundColor": "transparent",
            "bold": false,
            "color": "#3498DB",
            "italic": true,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "todo",
            "backgroundColor": "transparent",
            "bold": true,
            "color": "#FF8C00",
            "italic": false,
            "strikethrough": false,
            "underline": false,
        },
        {
            "tag": "//",
            "backgroundColor": "transparent",
            "bold": false,
            "color": "#474747",
            "italic": false,
            "strikethrough": true,
            "underline": false,
        },
    ],
    "chat.agent.enabled": false,
    "clangd.inactiveRegions.opacity": 0.6,
    "editor.accessibilitySupport": "off",
    "editor.fontFamily": "MesloLGM Nerd Font, monospace",
    "editor.minimap.renderCharacters": false,
    "editor.minimap.size": "fit",
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.exclude": {
        "**/.git": false,
    },
    "files.readonlyInclude": {
        "**/.cargo/registry/src/**/*.rs": true,
        "**/.cargo/git/checkouts/**/*.rs": true,
        "**/lib/rustlib/src/rust/library/**/*.rs": true,
    },
    "files.trimTrailingWhitespace": true,
    "git.enableSmartCommit": true,
    "python.languageServer": "Jedi",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "ruff.nativeServer": "on",
    "rust-analyzer.showDependenciesExplorer": false,
    "rust-analyzer.diagnostics.enable": false,
    "rust-analyzer.restartServerOnConfigChange": true,
    "rust-analyzer.inlayHints.chainingHints.enable": false,
    "rust-analyzer.inlayHints.typeHints.enable": false,
    "rust-analyzer.inlayHints.renderColons": false,
    "rust-analyzer.inlayHints.typeHints.hideClosureInitialization": true,
    "rust-analyzer.inlayHints.typeHints.hideClosureParameter": true,
    "rust-analyzer.inlayHints.typeHints.hideNamedConstructor": true,
    "rust-analyzer.lens.enable": false,
    "security.workspace.trust.untrustedFiles": "newWindow",
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.linux": "Nushell",
    "terminal.integrated.fontFamily": "MesloLGM Nerd Font",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.profiles.linux": {
        "JavaScript Debug Terminal": null,
    },
    "terminal.integrated.profiles.windows": {
        "JavaScript Debug Terminal": null,
    },
    "update.showReleaseNotes": false,
    "window.commandCenter": false,
    "window.menuBarVisibility": "compact",
    "workbench.activityBar.location": "top",
    "workbench.colorTheme": "Kary Pro Colors － Dark",
    "workbench.cloudChanges.autoResume": "off",
    "workbench.cloudChanges.continueOn": "off",
    "workbench.editor.editorActionsLocation": "hidden",
    "workbench.enableExperiments": false,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.layoutControl.enabled": false,
    "workbench.navigationControl.enabled": false,
    "workbench.productIconTheme": "material-product-icons",
    "workbench.preferredDarkColorTheme": "Kary Pro Colors － Dark",
    "workbench.preferredLightColorTheme": "Kary Pro Colors － Light",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "workbench.welcomePage.extraAnnouncements": false,
}
